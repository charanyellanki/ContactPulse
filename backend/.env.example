# GCP project & data plane
# Auth: Application Default Credentials. Run once locally:
#   gcloud auth application-default login
#   gcloud config set project contactpulse-dev
PROJECT_ID=contactpulse-dev
GCP_REGION=us-central1
BQ_DATASET=contactpulse
GCS_BUCKET=contactpulse-audio

# Live voice (Gemini Live API on Vertex AI; see CLAUDE.md §14).
# Vertex Live model availability is per-project — verify with:
#   PROJECT=$(gcloud config get-value project)
#   curl -H "Authorization: Bearer $(gcloud auth print-access-token)" \
#        -H "x-goog-user-project: $PROJECT" \
#        "https://us-central1-aiplatform.googleapis.com/v1beta1/publishers/google/models?pageSize=200" \
#        | python3 -c "import json,sys; [print(m['name']) for m in json.load(sys.stdin).get('publisherModels',[]) if 'live' in m['name']]"
# Region must support Live — us-central1 is the safe default.
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_LIVE_REGION=us-central1
GEMINI_LIVE_VOICE=Aoede
GEMINI_LIVE_LANGUAGE=en-US
# Soft cap on a single Live WebSocket session to avoid runaway cost.
GEMINI_LIVE_SESSION_MAX_SECONDS=600

# Models (CLAUDE.md §6: never hardcode in business code)
# Using 2.5 family — 2.0 IDs were not yet GA on the dev project at bootstrap.
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# Agent pipeline thresholds
ROUTER_CONFIDENCE_THRESHOLD=0.6
GROUNDING_MIN_SCORE=0.8
MAX_GROUNDING_RETRIES=1

# Eval — minimum reranker score for a retrieval result to count as a "hit"
RETRIEVAL_HIT_THRESHOLD=0.5

# Circuit breaker (per-service failure budget over a sliding window)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_WINDOW_SECONDS=60

# DLP
DLP_ENABLED=true

# Runtime
ENVIRONMENT=development
API_VERSION=0.1.0
